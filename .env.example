# ============================================
# xiaobaigame Environment Variables
# ============================================
# Copy this file to .env and fill in values.
# Never commit .env to version control.

# ---- Project ----
PROJECT_NAME=xiaobaigame
VERSION=0.1.0
DEBUG=false

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/xiaobaigame

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- JWT ----
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- MinIO / S3 ----
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=xiaobaigame
S3_SECURE=false

# ---- Celery (reserved) ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
